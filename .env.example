# 团队共用：复制本文件为 .env.development（本地 npm run dev:h5 会读取）
# 保证「代理目标」与「直连基址」指向同一套后端，否则别人电脑会 404。

# 只写到主机:端口，末尾不要加 /api（接口路径里已有 /api）
VITE_PROXY_TARGET=http://120.27.137.241:8081
VITE_API_BASE_URL=http://120.27.137.241:8081/

# H5 默认直连 VITE_API_BASE_URL；只有需要 Vite 代理时再设为 1（未代理时不要用相对路径打 5173）
# VITE_H5_USE_PROXY=1

# 仅当后端没有 /api 前缀时才设为 1（与 Swagger 带 /api 时不要开）
# VITE_API_STRIP_PREFIX=1

# 请求超时（毫秒），默认 25000；同事跨省/校园网仍超时再调大，例如 40000
# VITE_REQUEST_TIMEOUT_MS=40000

