# Swagger 服务地址（仅当 H5 开启 VITE_H5_USE_PROXY=1 时用 Vite 转发）
VITE_PROXY_TARGET=http://120.27.137.241:8081

# H5 默认直连该地址（避免同事环境未加载代理时 localhost:5173/api 报 404）
VITE_API_BASE_URL=http://120.27.137.241:8081/

# 若仍坚持走本地代理再打开（需后端允许跨域时可关代理改直连）
# VITE_H5_USE_PROXY=1

# 后端路径为 /api/auth/register 等，必须关闭「去 /api」
# VITE_API_STRIP_PREFIX=1
