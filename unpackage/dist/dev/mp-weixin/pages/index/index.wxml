<view class="login-container"><view class="login-form"><view class="input-group"><text class="input-label">手机号</text><input type="number" class="input" placeholder="请输入手机号" placeholder-class="placeholder" value="{{a}}" bindinput="{{b}}"/></view><view class="input-group password-group"><text class="input-label">密码</text><view class="password-input-container"><block wx:if="{{r0}}"><input type="{{c}}" class="input" placeholder="请输入密码" placeholder-class="placeholder" value="{{d}}" bindinput="{{e}}"/></block><view class="password-toggle" bindtap="{{g}}"><text class="iconfont">{{f}}</text></view></view></view><button class="login-btn" bindtap="{{h}}">登录</button><view class="forgot-password" bindtap="{{i}}">忘记密码</view><view class="register-container"><text>还没有账号？？</text><text class="register-link" bindtap="{{j}}">立即注册</text></view></view></view>